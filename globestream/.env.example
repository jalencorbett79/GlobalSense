# GlobeStream Configuration
# Copy this file to .env and fill in your values

# Proxy API Backend URL (base URL only — do NOT include /api/proxy suffix)
# For local dev with the Express server:
VITE_PROXY_API_URL=http://localhost:3001
# For separate Render deployment, use your backend service URL:
# VITE_PROXY_API_URL=https://your-backend.onrender.com
# For single-service deployment (backend serves frontend), leave empty or omit:
# VITE_PROXY_API_URL=

# Optional: Analytics endpoint
VITE_ANALYTICS_URL=

# TMDB API Key (get one at https://www.themoviedb.org/settings/api)
# This is used by the backend (server/.env), not the frontend.
# TMDB_KEY=your_api_key_here

# ─── Proxy Provider API Keys (set in server/.env) ────────────────────
# These providers are used as fallbacks when direct proxies are offline.
# Get free API keys at each provider's site. Only configure the ones you want.

# ScraperAPI — https://www.scraperapi.com (5,000 free credits/month)
# SCRAPERAPI_KEY=your_scraperapi_key

# Crawlbase (formerly ProxyCrawl) — https://crawlbase.com (1,000 free requests)
# CRAWLBASE_TOKEN=your_crawlbase_token

# WebScrapingAPI — https://www.webscrapingapi.com (1,000 free requests/month)
# WEBSCRAPINGAPI_KEY=your_webscrapingapi_key

# Bright Data — https://brightdata.com (free trial with limited bandwidth)
# BRIGHTDATA_USERNAME=your_username
# BRIGHTDATA_PASSWORD=your_password
# BRIGHTDATA_HOST=brd.superproxy.io
# BRIGHTDATA_PORT=22225
